{
  "name": "kalimotxo",
  "version": "1.1.0",
  "description": "Windows gaming on Apple Silicon",
  "main": "build/main/main.js",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "Kalimotxo contributors",
  "homepage": "https://github.com/segux/kalimotxo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/segux/kalimotxo.git"
  },
  "bugs": {
    "url": "https://github.com/segux/kalimotxo/issues"
  },
  "keywords": [
    "wine",
    "macos",
    "apple-silicon",
    "battle-net",
    "diablo",
    "electron",
    "dxmt",
    "d3dmetal",
    "game-porting-toolkit"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "start:ui": "ELECTRON_RUN_AS_NODE= KALIMOTXO_UI_PREVIEW=1 electron-vite dev",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "codecheck": "tsc --noEmit",
    "test": "jest",
    "test:battlenet": "jest src/backend/storeManagers/battlenet",
    "icon:export": "node scripts/export-app-icon.mjs",
    "predist:mac": "node scripts/export-app-icon.mjs && node scripts/dmg-background.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "fetch:tools": "node scripts/sync-bundled-tools.mjs",
    "postinstall": "node scripts/sync-bundled-tools.mjs",
    "cli:repair": "node scripts/repair-runtime.mjs",
    "cli:launch": "electron-vite build && electron . --kalimotxo-cli=repair-launch",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "i18next": "^26.3.0",
    "lucide-react": "^0.503.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "playwright": "^1.60.0",
    "semantic-release": "^24.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.4",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.kalimotxo.app",
    "productName": "Kalimotxo",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 658,
        "height": 498
      },
      "contents": [
        {
          "x": 160,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "dist/mac"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bundled",
        "to": "bundled",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
